<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/background2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"
                android:paddingTop="48dp">

                <!-- Back + Title -->
                <TextView
                    android:id="@+id/btnBackDaily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="‹"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily Activity"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:paddingStart="4dp" />

                <!-- Calendar icon to open date picker -->
                <TextView
                    android:id="@+id/btnCalendar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/tab_inactive_bg"
                    android:gravity="center"
                    android:text="📅"
                    android:textSize="18sp" />

                <!-- Profile Image -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/dailyProfileImageCard"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/dailyProfileImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/vector" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== HORIZONTAL DAY SELECTOR ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#991B7999"
                app:cardCornerRadius="16dp">

                <HorizontalScrollView
                    android:id="@+id/dayScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="12dp"
                    android:scrollbars="none"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/dayContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </HorizontalScrollView>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== SELECTED DAY INFO CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#991B7999"
                app:cardCornerRadius="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Activity rings for selected day (Centered) -->
                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/dayRingOuter"
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_gravity="center"
                            android:progress="0"
                            app:indicatorColor="#4CAF50"
                            app:indicatorSize="160dp"
                            app:trackColor="#224CAF50"
                            app:trackThickness="16dp" />

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/dayRingMiddle"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:progress="0"
                            app:indicatorColor="#15BDD7"
                            app:indicatorSize="120dp"
                            app:trackColor="#2215BDD7"
                            app:trackThickness="16dp" />

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/dayRingInner"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            android:progress="0"
                            app:indicatorColor="#E91E63"
                            app:indicatorSize="80dp"
                            app:trackColor="#22E91E63"
                            app:trackThickness="16dp" />
                    </FrameLayout>

                    <!-- Horizontal Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Steps -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Steps"
                                android:textColor="#AAFFFFFF"
                                android:textSize="12sp" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="top"
                                android:orientation="horizontal">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp"
                                    android:layout_marginTop="1dp" android:layout_marginEnd="6dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/step"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#4CAF50" />
                                <TextView
                                    android:id="@+id/txtDaySteps"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="4500\n/6000"
                                    android:gravity="start"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Active Time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active time"
                                android:textColor="#AAFFFFFF"
                                android:textSize="12sp" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="top"
                                android:orientation="horizontal">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp"
                                    android:layout_marginTop="1dp" android:layout_marginEnd="6dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/time"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#15BDD7" />
                                <TextView
                                    android:id="@+id/txtDaySleep"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="70\n/90 mins"
                                    android:gravity="start"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Calories -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calories"
                                android:textColor="#AAFFFFFF"
                                android:textSize="12sp" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="top"
                                android:orientation="horizontal">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp"
                                    android:layout_marginTop="1dp" android:layout_marginEnd="6dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/kcal"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#E91E63" />
                                <TextView
                                    android:id="@+id/txtDayFood"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="300\n/500 kcal"
                                    android:gravity="start"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Details rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total burnt calories "
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/dotted_line"
                            android:layerType="software" />
                        <TextView
                            android:id="@+id/txtTotalCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1895 kcal"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance while active "
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/dotted_line"
                            android:layerType="software" />
                        <TextView
                            android:id="@+id/txtDayDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.05 km"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== STEPS CHART CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#991B7999"
                app:cardCornerRadius="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Chart header + toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Steps"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Weekly / Monthly toggle -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/tab_inactive_bg"
                            android:orientation="horizontal"
                            android:padding="3dp">

                            <TextView
                                android:id="@+id/btnWeekly"
                                android:layout_width="72dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/tab_active_bg"
                                android:gravity="center"
                                android:text="Weekly"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnMonthly"
                                android:layout_width="72dp"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="Monthly"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Steps total for period -->
                    <TextView
                        android:id="@+id/txtChartTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />

                    <!-- Bar chart (horizontal scroll for monthly) -->
                    <HorizontalScrollView
                        android:id="@+id/chartScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:scrollbars="none">

                        <!-- Bars added programmatically -->
                        <LinearLayout
                            android:id="@+id/chartContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="120dp"
                            android:gravity="bottom"
                            android:orientation="horizontal" />

                    </HorizontalScrollView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#001B29"
        android:paddingBottom="0dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_menu"
        style="@style/NoIndicatorBottomNav" />

</androidx.constraintlayout.widget.ConstraintLayout>
