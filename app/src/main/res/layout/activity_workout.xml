<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/background2" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44001B29" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="48dp"
                android:paddingStart="30dp"
                android:paddingEnd="32dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Workout"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#3315BDD7">
                    <ImageView
                        android:id="@+id/profileIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/startpagegirl"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/search_bar_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/searchWorkout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:hint="Search"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#AAFFFFFF"
                    android:textSize="16sp"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙"
                    android:textSize="18sp" />

            </LinearLayout>

            <!-- Popular Workout Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/workout_card_bg"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:paddingBottom="20dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popular Workout"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp" />

                <!-- Popular Workout Horizontal Scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="16dp"
                    android:paddingStart="16dp"
                    android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Popular Card 1 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPopular1"
                        android:layout_width="260dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imagePopular1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pw1" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Home Workouts\nfor Beginners"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_gravity="center_horizontal"
                                android:gravity="center" />
                                
                            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_horizontal">
                                
                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="9 days"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>
                                    
                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🕒 20 mins/day"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Popular Card 2 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPopular2"
                        android:layout_width="260dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="20dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imagePopular2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pw2" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Effective Home\nWorkout Routines"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_gravity="center_horizontal"
                                android:gravity="center" />
                                
                            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_horizontal">
                                
                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="9 days"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>
                                    
                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🕒 30 mins/day"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Popular Card 3 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPopular3"
                        android:layout_width="260dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="20dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imagePopular3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pw3" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outside Workout \n for Beginner"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_gravity="center_horizontal"
                                android:gravity="center" />

                            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_horizontal">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="9 days"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>

                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFFFFF">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🕒 30 mins/day"
                                        android:textColor="#000000"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp" />
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>
            </LinearLayout>

            <!-- Program Type Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/workout_card_bg"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:paddingBottom="20dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Program Type"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="20dp" />

                <!-- Program Type Horizontal Scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="16dp"
                    android:paddingStart="20dp"
                    android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Program Card 1: Full Body -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/programFullBody"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageProgramFullBody"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pt1" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Full Body"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Program Card 2: Arms -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/programArms"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageProgramArms"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pt2" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Arms"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Program Card 2: Led -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/programLegs"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageProgramLegs"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pt3" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Legs"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Program Card 3: ABS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/programAbs"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="20dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageProgramAbs"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pt4" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="ABS"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>
            </LinearLayout>

            <!-- Yoga Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/workout_card_bg"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:paddingBottom="20dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="20dp" />

                <!-- Yoga Horizontal Scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="16dp"
                    android:paddingStart="20dp"
                    android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Yoga Card 1 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/yogaAccomplish"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageYogaAccomplish"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/y1" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Accomplish"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Yoga Card 2 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/yogaDancer"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageYogaDancer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/y2" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Dancer's"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Yoga Card 3 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/yogaCrescent"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="20dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageYogaCrescent"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/y3" />
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />
                            
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Crescent\nLunge"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Yoga Card 4 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/yogaMorning"
                        android:layout_width="120dp"
                        android:layout_height="170dp"
                        android:layout_marginEnd="20dp"
                        app:cardCornerRadius="16dp">

                        <ImageView
                            android:id="@+id/imageYogaMorning"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/y4" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#44000000" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Mornig \nYoga"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#001B29"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/NoIndicatorBottomNav"
        android:paddingBottom="0dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
