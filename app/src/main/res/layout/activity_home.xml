<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/background2" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="30dp"
                android:paddingEnd="32dp"
                android:paddingTop="48dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Dynamic username loaded from SharedPreferences -->
                    <TextView
                        android:id="@+id/txtGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello, User!"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Let's check your activity!"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/homeProfileImageCard"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:id="@+id/homeProfileImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/vector" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== DAILY BALANCE CARD (clickable → DailyActivity) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDailyBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#991B7999"
                app:cardCornerRadius="24dp"
                app:rippleColor="#3315BDD7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your daily Balance"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Tap to expand hint -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View details ›"
                            android:textColor="#15BDD7"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Rings + Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Three Concentric Rings -->
                        <FrameLayout
                            android:layout_width="148dp"
                            android:layout_height="148dp">

                            <!-- Outer ring: Steps -->
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/ringSteps"
                                android:layout_width="148dp"
                                android:layout_height="148dp"
                                android:layout_gravity="center"
                                android:progress="0"
                                app:indicatorColor="#4CAF50"
                                app:indicatorSize="148dp"
                                app:trackColor="#224CAF50"
                                app:trackThickness="12dp" />

                            <!-- Middle ring: Active Time -->
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/ringActive"
                                android:layout_width="116dp"
                                android:layout_height="116dp"
                                android:layout_gravity="center"
                                android:progress="0"
                                app:indicatorColor="#15BDD7"
                                app:indicatorSize="116dp"
                                app:trackColor="#2215BDD7"
                                app:trackThickness="12dp" />

                            <!-- Inner ring: Calories -->
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/ringCalories"
                                android:layout_width="84dp"
                                android:layout_height="84dp"
                                android:layout_gravity="center"
                                android:progress="0"
                                app:indicatorColor="#E91E63"
                                app:indicatorSize="84dp"
                                app:trackColor="#22E91E63"
                                app:trackThickness="12dp" />

                        </FrameLayout>

                        <!-- Stats Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="20dp">

                            <!-- Calories row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/kcal"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#E91E63" />
                                <TextView
                                    android:id="@+id/txtCaloriesStats"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="  -- kcal"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Steps row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginTop="14dp"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/step"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#4CAF50" />
                                <TextView
                                    android:id="@+id/txtStepsStats"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="  0 steps"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Sleep row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:layout_marginTop="14dp"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/time"
                                    android:background="@drawable/circle_background"
                                    android:backgroundTint="#15BDD7" />
                                <TextView
                                    android:id="@+id/txtActiveStats"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="  -- sleep"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== METRIC CARDS ROW 1: Sleep + Food ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingHorizontal="20dp"
                android:orientation="horizontal">

                <!-- SLEEP CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#991B7999"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="😴 Sleep"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnSleepEnter"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_enter"
                                android:backgroundTint="#2215BDD7"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Enter"
                                android:textColor="#15BDD7"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressSleep"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            app:indicatorColor="#15BDD7"
                            app:trackColor="#3315BDD7"
                            app:trackCornerRadius="3dp" />

                        <TextView
                            android:id="@+id/txtSleepValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="-- h --m"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- FOOD CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#991B7999"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🍎 Food"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnFoodEnter"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_enter"
                                android:backgroundTint="#2215BDD7"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Enter"
                                android:textColor="#15BDD7"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressFood"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            app:indicatorColor="#FF9800"
                            app:trackColor="#33FF9800"
                            app:trackCornerRadius="3dp" />

                        <TextView
                            android:id="@+id/txtFoodValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="-- kcal"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== METRIC CARDS ROW 2: Body Comp + Blood Pressure ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp"
                android:orientation="horizontal">

                <!-- BODY COMP CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#991B7999"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="💪 Body"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnBodyEnter"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_enter"
                                android:backgroundTint="#2215BDD7"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Enter"
                                android:textColor="#15BDD7"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBody"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            app:indicatorColor="#4CAF50"
                            app:trackColor="#224CAF50"
                            app:trackCornerRadius="3dp" />

                        <TextView
                            android:id="@+id/txtBodyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="-- % fat"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BLOOD PRESSURE CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#991B7999"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="❤️ BP"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnBpEnter"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/btn_enter"
                                android:backgroundTint="#2215BDD7"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Enter"
                                android:textColor="#15BDD7"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBp"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="75"
                            app:indicatorColor="#F44336"
                            app:trackColor="#33F44336"
                            app:trackCornerRadius="3dp" />

                        <TextView
                            android:id="@+id/txtBpValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="--/-- mmHg"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== WATER INTAKE CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#991B7999"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title row + +250ml button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💧 Water Intake"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtWaterGlasses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="0 / 8 glasses"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- +250ml Button -->
                        <TextView
                            android:id="@+id/btnAddWater"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/rounded_button"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="+ 250 ml"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Water level progress -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressWater"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="14dp"
                        android:progress="0"
                        app:indicatorColor="#15BDD7"
                        app:trackColor="#3315BDD7"
                        app:trackCornerRadius="5dp" />

                    <!-- ml counter -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtWaterValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0 ml"
                            android:textColor="#15BDD7"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 2000 ml"
                            android:textColor="#CCFFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#001B29"
        android:paddingBottom="0dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_menu"
        style="@style/NoIndicatorBottomNav" />

</androidx.constraintlayout.widget.ConstraintLayout>
