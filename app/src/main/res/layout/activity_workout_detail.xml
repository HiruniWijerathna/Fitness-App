<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001B29">

    <!-- Hero Image Area -->
    <ImageView
        android:id="@+id/heroImage"
        android:layout_width="0dp"
        android:layout_height="400dp"
        android:contentDescription="Workout hero"
        android:scaleType="centerCrop"
        android:src="@drawable/background2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark gradient overlay on hero -->
    <View
        android:layout_width="0dp"
        android:layout_height="400dp"
        android:background="@drawable/bottom_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back Arrow -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◀"
        android:textColor="#15BDD7"
        android:textSize="24sp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="32dp" />

    <!-- Workout Title on Image -->
    <LinearLayout
        android:id="@+id/heroInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="@id/heroImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/workoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Body Workout"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView 
                android:id="@+id/workoutSubtitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Type : Weight Loss, Full Body"
                android:textColor="#CCFFFFFF" android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/heroImage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:paddingBottom="120dp">

            <!-- Week 1 Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Week 1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▲"
                    android:textColor="#15BDD7"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Day 1 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day1Item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#3315BDD7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="8dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/day1Image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/startpagegirl"
                                android:scaleType="centerCrop"/>
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#44000000" />
                            <androidx.cardview.widget.CardView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:cardCornerRadius="14dp"
                                app:cardBackgroundColor="#FFFFFF"
                                android:layout_gravity="center">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="▶"
                                    android:textColor="#1B7999"
                                    android:textSize="14sp"
                                    android:gravity="center"
                                    android:paddingStart="2dp"/>
                            </androidx.cardview.widget.CardView>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                        
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="Day 1" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                            <TextView android:text="25 mint" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        
                        <TextView android:id="@+id/day1Title" android:text="Full Body" android:textColor="#FFFFFF" android:textSize="16sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                            
                        <TextView android:text="3 step | 20 Exercises" android:textColor="#FFFFFF"
                            android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                        <TextView android:text="30-40 secs on | 5-10 secs off" android:textColor="#FFFFFF"
                            android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#15BDD7"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            
            <!-- Day 2 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day2Item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#3315BDD7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="8dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/day2Image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/background2"
                                android:scaleType="centerCrop"/>
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#44000000" />
                            <androidx.cardview.widget.CardView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:cardCornerRadius="14dp"
                                app:cardBackgroundColor="#FFFFFF"
                                android:layout_gravity="center">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="▶"
                                    android:textColor="#1B7999"
                                    android:textSize="14sp"
                                    android:gravity="center"
                                    android:paddingStart="2dp"/>
                            </androidx.cardview.widget.CardView>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                        
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="Day 1" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                            <TextView android:text="25 mint" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        
                        <TextView android:id="@+id/day2Title" android:text="Arms Upper Body" android:textColor="#FFFFFF" android:textSize="16sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                            
                        <TextView android:text="3 step | 20 Exercises" android:textColor="#FFFFFF"
                            android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                        <TextView android:text="30-40 secs on | 5-10 secs off" android:textColor="#FFFFFF"
                            android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#15BDD7"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Day 3 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day3Item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#3315BDD7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="8dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/day3Image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/startpagegirl"
                                android:scaleType="centerCrop"/>
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#44000000" />
                            <androidx.cardview.widget.CardView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:cardCornerRadius="14dp"
                                app:cardBackgroundColor="#FFFFFF"
                                android:layout_gravity="center">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="▶"
                                    android:textColor="#1B7999"
                                    android:textSize="14sp"
                                    android:gravity="center"
                                    android:paddingStart="2dp"/>
                            </androidx.cardview.widget.CardView>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                        
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="Day 1" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                            <TextView android:text="25 mint" android:textColor="#FFFFFF" android:textSize="12sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        
                        <TextView android:id="@+id/day3Title" android:text="Booty &amp; Legs" android:textColor="#FFFFFF" android:textSize="16sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#15BDD7"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
                
                <!-- Overlay over the bottom card to match the "Start this challenge" button placing if needed, but we can put it below -->

            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Start Challenge Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnStartChallenge"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="#7EF0F8"
        android:text="Start this challenge"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#001B29"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/NoIndicatorBottomNav"
        android:paddingBottom="0dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
