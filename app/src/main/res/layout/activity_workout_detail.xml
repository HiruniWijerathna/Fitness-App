<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001B29">

    <!-- Hero Image Area -->
    <ImageView
        android:id="@+id/heroImage"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:contentDescription="Workout hero"
        android:scaleType="centerCrop"
        android:src="@drawable/background2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dark gradient overlay on hero -->
    <View
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:background="@drawable/bottom_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back Arrow -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="‹"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="36dp" />

    <!-- Workout Title on Image -->
    <LinearLayout
        android:id="@+id/heroInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="@id/heroImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Body Workout"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Type - Weight Loss, Full Body"
                android:textColor="#CCFFFFFF" android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/heroImage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Week 1 Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Week 1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp" />

            <!-- Day 1 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day1Item"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#991B7999">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#3315BDD7">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:text="🏃" android:textSize="20sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:text="Day 1" android:textColor="#CCFFFFFF" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Full Body" android:textColor="#FFFFFF" android:textSize="15sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="3 Sets | 12 Exercises | 30 min" android:textColor="#AAFFFFFF"
                            android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textColor="#15BDD7" android:textSize="22sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Day 2 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day2Item"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#991B7999">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#3315BDD7">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:text="💪" android:textSize="20sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:text="Day 2" android:textColor="#CCFFFFFF" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Arms Upper Body" android:textColor="#FFFFFF" android:textSize="15sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="3 Sets | 10 Exercises | 25 min" android:textColor="#AAFFFFFF"
                            android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textColor="#15BDD7" android:textSize="22sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Week 2 Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Week 2"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <!-- Day 3 Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/day3Item"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#991B7999">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#3315BDD7">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:text="🏋" android:textSize="20sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:text="Day 3" android:textColor="#CCFFFFFF" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Booty &amp; Legs" android:textColor="#FFFFFF" android:textSize="15sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="4 Sets | 14 Exercises | 35 min" android:textColor="#AAFFFFFF"
                            android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textColor="#15BDD7" android:textSize="22sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Music 1 Item (Start this Challenge button at bottom) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#991B7999">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#3315BDD7">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:text="🎵" android:textSize="20sp" android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:text="Music 1" android:textColor="#CCFFFFFF" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Full Body" android:textColor="#FFFFFF" android:textSize="15sp"
                            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="3 Sets | 12 Exercises | 30 min" android:textColor="#AAFFFFFF"
                            android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Progress Bar indicator -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        app:indicatorColor="#15BDD7"
                        app:trackColor="#3315BDD7"
                        app:trackCornerRadius="3dp"
                        android:progress="75" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Start this Challenge Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStartChallenge"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_button"
                android:text="Start this Challenge"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
